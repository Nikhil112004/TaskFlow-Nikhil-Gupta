# PostgreSQL
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_secret
POSTGRES_DB=taskflow
POSTGRES_PORT=5432
DATABASE_URL=postgresql://taskflow:taskflow_secret@localhost:5432/taskflow

# Backend
JWT_SECRET=change_me_in_production_please_use_a_long_random_string
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
PG_CONNECTION_TIMEOUT_MS=15000

# Frontend
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000
FRONTEND_PORT=3000

# WebSocket (defaults to same host as API, replacing http with ws)
# Only set this if WS is on a different host/port
# VITE_WS_URL=ws://localhost:4000
